# 前端线上 API 地址；本地留空时继续使用 Vite /api proxy
VITE_API_BASE_URL=

# 通义千问 API Key（仅供后端读取，请勿添加 VITE_ 前缀）
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# 两个 Key 变量均支持；若同时配置，优先使用 DASHSCOPE_API_KEY
# QWEN_API_KEY=sk-your-qwen-api-key

# Base URL 不要包含 /chat/completions，adapter 会自动拼接
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_JUDGE_MODEL=qwen-plus
PORT=3001

# 线上前端 Origin，例如 https://your-app.vercel.app；本地地址默认已允许
CORS_ORIGIN=
